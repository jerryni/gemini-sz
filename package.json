{
  "name": "gemini-sz",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 5555",
    "build": "next build",
    "preview": "opennextjs-cloudflare build && wrangler dev",
    "d": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "migrate": "npx wrangler d1 execute gemini-sz-db --local --file=./migrations/0001_init.sql",
		"migrate:db": "wrangler d1 migrations apply DB --local",
		"migrate:db-remote": "wrangler d1 migrations apply DB --remote",
    "migrate-remote": "npx wrangler d1 execute gemini-sz-db --remote --file=./migrations/0001_init.sql",
    "migrate-gemini-keys": "npx wrangler d1 execute gemini-sz-db --local --file=./migrations/0002_gemini_keys.sql",
    "migrate-gemini-keys-remote": "npx wrangler d1 execute gemini-sz-db --remote --file=./migrations/0002_gemini_keys.sql",
    "typecheck": "tsc --noEmit",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.18.0",
    "lucide-react": "^0.542.0",
    "next": "^16.2.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "typescript": "^5.9.3",
    "wrangler": "^4.46.0"
  }
}
